# File di esempio per .env.local (NON committato — vedi .gitignore).
# Copia questo file in `.env.local` e riempi i valori.

# Personal Access Token Supabase per la Management API.
# Generare su: https://supabase.com/dashboard/account/tokens
# Usato da scripts/run-sql.mjs per eseguire SQL diretto sul DB.
SUPABASE_PAT=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Opzionale) Forza il project ref. Se assente viene estratto da
# VITE_SUPABASE_URL nel file `.env`.
# SUPABASE_PROJECT_REF=mreftuajsrinrsvpeicq
